# ============================================================
# Railway Environment Variables — Thailand Hayom
# Copy these into Railway Dashboard → Your Project → Variables
# ============================================================

# ----- REQUIRED -----

# PostgreSQL connection string
# Railway auto-provides this if you add a Postgres plugin
# Otherwise use your Supabase URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — CHANGE THIS to a random 32+ char string
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-random-32-char-secret

# Node environment
NODE_ENV=production

# ----- AI / LLM -----

# OpenAI API key — used by the AI chat concierge
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# (Optional) Override OpenAI model. Default: gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# (Optional) Use a different OpenAI-compatible API base URL
# OPENAI_API_BASE_URL=https://api.openai.com

# ----- PAYMENTS -----

# Stripe secret key (sk_live_... for production, sk_test_... for testing)
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- EMAIL -----

# Resend API key for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ----- ADMIN -----

# The openId of the first admin user (set after first login)
# Leave blank — after deploying, register an account, find your openId
# in the database, then set this to grant admin role.
# OWNER_OPEN_ID=local_xxxxxxxxxxxxxxxxxxxx

# ----- OPTIONAL (Manus-era, not needed on Railway) -----
# OAUTH_SERVER_URL=    # Manus OAuth — not needed
# BUILT_IN_FORGE_API_URL=  # Manus LLM proxy — not needed (use OPENAI_API_KEY)
# BUILT_IN_FORGE_API_KEY=  # Manus LLM key — not needed
# VITE_APP_ID=         # Manus app ID — not needed
# VITE_OAUTH_PORTAL_URL=  # Manus portal — not needed
